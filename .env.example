# EinVault environment configuration
# Used by docker-compose.dev.yml or for local dev; place this file as .env next to it.
# For production (docker-compose.prod.yml), edit the values directly in that file instead.
# Variables can also be passed inline or exported in your shell.

# Required

# Public URL of your EinVault instance.
# Must match the address users access the app from (used for CSRF protection).
ORIGIN=https://einvault.yourdomain.com

# Optional: container

# Container timezone (default: UTC).
# Set to your local timezone so dates and times display correctly.
# Uses IANA timezone names: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
# TZ=America/New_York

# UID/GID the container process runs as (default: 1000:1000).
# Set to match the owner of your data directory to avoid permission issues.
# Run `id` on your host to check your UID/GID.
# PUID=1000
# PGID=1000

# Host path for EinVault's data (SQLite database and photo uploads).
# Pre-create this directory before first run to control ownership.
# EINVAULT_DATA=./data

# Host interface and port (default: loopback on 3000).
# Change EINVAULT_HOST only if your proxy requires a different binding.
# For Docker-network proxies (Traefik/Caddy in Docker), use the networks option
# in the compose file instead. See the README for details.
# EINVAULT_HOST=127.0.0.1
# EINVAULT_PORT=3000

# Optional: app

# Maximum file size in MB for avatar and journal photo uploads (default: 10).
# If you raise this above 50, raise BODY_SIZE_LIMIT to match.
# UPLOAD_MAX_MB=10

# SvelteKit's internal request body cap (default: 50M).
# Must be >= UPLOAD_MAX_MB. SvelteKit enforces this before the upload handler runs,
# so it needs to be high enough to let requests through. Accepts K, M, G suffixes.
# BODY_SIZE_LIMIT=50M

# Override the database path inside the container (rarely needed).
# Defaults to /data/einvault.db, which maps to EINVAULT_DATA on the host.
# DATABASE_URL=/data/einvault.db
